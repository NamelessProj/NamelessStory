{
  "settings": {
    "startingScene": "start",
    "textSpeed": 45,
    "defaultNameDisplay": "short",
    "defaultDialoguePosition": "bottom",
    "defaultSceneTransition": "fade",
    "defaultDialogueTransition": "none",
    "transitionDuration": 400,
    "titlePage": {
      "title": "The Feature Tour",
      "background": "title_bg.png",
      "logo": "logo.png",
      "showTitle": true,
      "buttons": {
        "start": "Begin Tour",
        "continue": "Resume",
        "load": "Load Save",
        "credits": "Credits"
      }
    },
    "creditsPage": {
      "title": "– Credits –",
      "background": "title_bg.png",
      "scrollSpeedInPixelsPerSecond": 50,
      "creditGroups": [
        {
          "groupName": "Story & Writing",
          "credits": [
            { "name": "You", "role": "Author" }
          ]
        },
        {
          "groupName": "Engine",
          "credits": [
            { "name": "NamelessStory", "role": "Visual Novel Engine" }
          ]
        },
        {
          "groupName": "Special Thanks",
          "credits": [
            { "name": "The Player" }
          ]
        }
      ]
    }
  },
  "characters": {
    "Alice": {
      "name": "Alice",
      "fullName": "Alice Wonderland",
      "color": "#e07ae0",
      "sprite": {
        "idle": "alice_idle.png",
        "wave": "alice_wave.png",
        "happy": "alice_happy.png"
      }
    },
    "Bob": {
      "name": "Bob",
      "fullName": "Bob Builder",
      "color": "#4a9cf5",
      "sprite": {
        "idle": "bob_idle.png",
        "thinking": "bob_thinking.png"
      }
    },
    "playerName": {
      "name": "",
      "color": "#7fde6a"
    }
  },
  "story": {
    "start": {
      "background": "bg_library.png",
      "bgmFile": "music_01.mp3",
      "dialogues": [
        {
          "name": "",
          "text": "[i]Welcome to [b]The Feature Tour[/b].[/i][br]This story showcases [color=gold]every feature[/color] of the engine."
        },
        {
          "name": "",
          "text": "Text can be [b]bold[/b], [i]italic[/i], [u]underlined[/u], or [s]struck through[/s].",
          "dialoguePosition": "center",
          "transition": "fade"
        },
        {
          "name": "",
          "text": "Colors work too: [color=red]by name[/color], [color=#4a9cf5]by hex[/color], or [color=rgb(140,200,80)]by rgb[/color].",
          "dialoguePosition": "center"
        },
        {
          "name": "",
          "text": "Pauses add drama\\.. like that one\\,\\, or shorter ones.",
          "dialoguePosition": "center"
        },
        {
          "name": "",
          "text": "Line breaks allow multi-line text:[br]First line.[br]Second line.[br][br]And a paragraph gap.",
          "next": "name_input"
        }
      ]
    },
    "name_input": {
      "background": "bg_library.png",
      "bgmFile": "continue",
      "dialogues": [
        {
          "name": "Alice",
          "text": "Oh! A visitor. I'm [b]{{C!Alice}}[/b]\\, and you are...?",
          "sprite": {
            "name": "wave",
            "position": "right"
          },
          "input": {
            "value": "playerName",
            "color": "#7fde6a"
          },
          "dialoguePosition": "top"
        },
        {
          "name": "{{v!playerName}}",
          "text": "I'm [color=#7fde6a]{{v!playerName}}[/color]! Nice to meet you, {{Alice}}.",
          "dialoguePosition": "top",
          "next": "meet_bob"
        }
      ]
    },
    "meet_bob": {
      "background": "bg_park.png",
      "bgmFile": "music_02.mp3",
      "transition": "slide-left",
      "dialogues": [
        {
          "name": "",
          "text": "[i]A little later\\, in the park...[/i]",
          "dialoguePosition": "center"
        },
        {
          "name": "Alice",
          "text": "{{v!playerName}}, meet my friend [b]{{C!Bob}}[/b]!",
          "sprite": {
            "name": "happy",
            "position": "left"
          }
        },
        {
          "name": "Bob",
          "text": "Hey! {{c!Alice}} talks about you a lot.",
          "sprite": {
            "name": "idle",
            "position": "right",
            "mirror": true
          },
          "nameDisplay": "full"
        },
        {
          "name": "Alice",
          "text": "So {{v!playerName}}, what shall we do today?",
          "sprite": {
            "name": "idle",
            "position": "left"
          },
          "options": [
            { "text": "Visit the library", "next": "library" },
            { "text": "Go on an adventure", "next": "adventure" },
            { "text": "Skip straight to credits", "next": "__end__" }
          ]
        }
      ]
    },
    "library": {
      "background": "bg_library.png",
      "bgmFile": "continue[music_01.mp3]",
      "dialogues": [
        {
          "name": "Bob",
          "text": "The library! My favourite place.",
          "sprite": {
            "name": "thinking",
            "position": "center"
          }
        },
        {
          "name": "Bob",
          "text": "Did you know you can add [link href=\"https://github.com/NamelessProj/NamelessStory\"]clickable links[/link] to dialogue?",
          "textSpeed": 30
        },
        {
          "name": "",
          "text": "The light shifted as dusk crept in.",
          "background": "bg_library_evening.png"
        },
        {
          "name": "Alice",
          "text": "I prefer [class=whisper]whispering[/class] in here.",
          "sprite": {
            "name": "idle",
            "position": { "x": 200, "y": 0 }
          },
          "dialoguePosition": "top"
        },
        {
          "name": "Alice",
          "text": "Shall we head out?",
          "options": [
            { "text": "Go on the adventure after all", "next": "adventure" },
            { "text": "Call it a day", "next": "ending" }
          ]
        }
      ]
    },
    "adventure": {
      "background": "bg_forest.png",
      "bgmFile": "reset",
      "transition": "fade-to-black",
      "bgmLoop": false,
      "dialogues": [
        {
          "name": "",
          "text": "[b][color=orange]Adventure awaits![/color][/b]",
          "dialoguePosition": "center"
        },
        {
          "name": "Alice",
          "text": "The path splits ahead. Which way, {{v!playerName}}?",
          "sprite": {
            "name": "idle",
            "position": "left"
          },
          "options": [
            { "text": "Go left", "next": "adventure:3" },
            { "text": "Go right", "next": "adventure:4" }
          ]
        },
        {
          "name": "",
          "text": "You should never reach this line — options skip over it.",
          "next": "ending"
        },
        {
          "name": "Alice",
          "text": "[color=green]Left[/color] it is! The safe road home.",
          "sprite": {
            "name": "happy",
            "position": "left"
          },
          "next": "ending"
        },
        {
          "name": "Alice",
          "text": "[color=red]Right[/color]? Bold choice! Into the unknown.",
          "sprite": {
            "name": "wave",
            "position": "right",
            "mirror": true
          },
          "next": "ending"
        }
      ]
    },
    "ending": {
      "background": "bg_park.png",
      "bgmFile": "none",
      "dialogues": [
        {
          "name": "",
          "text": "[i]And so, [b]{{v!playerName}}[/b] spent a wonderful day with {{c!Alice}} and {{C!Bob}}.[/i]",
          "dialoguePosition": "center"
        },
        {
          "name": "",
          "text": "The [s]old world[/s] felt [color=gold]new[/color]\\.. [b][i]full of possibility.[/i][/b]",
          "dialoguePosition": "center",
          "textSpeed": 60
        },
        {
          "name": "",
          "text": "[b]THE END[/b]",
          "dialoguePosition": "center",
          "next": "__end__"
        }
      ]
    }
  }
}
